import hashlib
import requests

def check_password_pwned(password):
    # Hash the password using SHA-1
    sha1_password = hashlib.sha1(password.encode('utf-8')).hexdigest().upper()
    # Get the first 5 characters of the hash
    first5 = sha1_password[:5]
    rest_of_hash = sha1_password[5:]

    # Request to the Have I Been Pwned API
    url = f"https://api.pwnedpasswords.com/range/{first5}"
    response = requests.get(url)
    
    if response.status_code == 200:
        # Check if the remaining part of the hash appears in the response
        hashes = response.text.splitlines()
        for hash_info in hashes:
            hash_part, count = hash_info.split(":")
            if hash_part == rest_of_hash:
                return f"This password was found in {count} data breaches!"
        return "This password is safe (not found in breaches)."
    else:
        return "Error connecting to the API."

# Example usage
password = "1234567890"
result = check_password_pwned(password)
print(result)
