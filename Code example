import re

def password_strength(password):
    # Check the length of the password
    length_score = len(password) >= 8  # Password must be at least 8 characters long
    
    # Check for digits, letters, and special characters
    digit_score = bool(re.search(r'\d', password))       # At least one digit
    lower_score = bool(re.search(r'[a-z]', password))    # At least one lowercase letter
    upper_score = bool(re.search(r'[A-Z]', password))    # At least one uppercase letter
    special_score = bool(re.search(r'[\W_]', password))  # At least one special character
    
    # Check for common passwords (basic protection)
    common_passwords = ["password", "123456", "qwerty", "admin", "letmein"]
    common_score = password.lower() not in common_passwords  # Password should not be common
    
    # Sum the scores
    strength = sum([length_score, digit_score, lower_score, upper_score, special_score, common_score])
    
    # Evaluate based on the score
    if strength == 6:
        return "Very Strong"
    elif strength == 5:
        return "Strong"
    elif strength == 4:
        return "Medium"
    elif strength == 3:
        return "Weak"
    else:
        return "Very Weak"

# Example usage
password = "Passw0rd!"
strength = password_strength(password)
print(f"Password: {password} - {strength}")
